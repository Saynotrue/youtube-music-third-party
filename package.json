{
  "name": "youtube-lyrics-bar",
  "version": "1.0.0",
  "description": "YouTube Music Lyrics Bar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.youtube-lyrics-bar.app",
    "productName": "YouTube Lyrics Bar",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": ["dmg"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}